# AI Provider: "openai" | "gemini"
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=...

# Public URL (dev). Production: salin .env.production.example → .env.production
# ORIGIN dipakai adapter-node; VITE_APP_URL untuk CSRF (build + runtime).
# ORIGIN=http://localhost:5173
# VITE_APP_URL=http://localhost:5173

# Server bind (production / adapter-node)
# HOST=0.0.0.0
# PORT=3000

# Database path (SQLite). Production VPS: tetap file path, backup folder data/
DATABASE_URL=file:./data/ops-sis.db

# Upload storage (local filesystem; S3 belum diimplementasi)
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# S3 (production)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
