# AI Provider: "openai" | "gemini"
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=...

# Database path (SQLite for dev; production target: MySQL)
DATABASE_URL=file:./data/ops-sis.db

# Upload storage: "local" | "s3"
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# S3 (production)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
