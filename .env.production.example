# Salin ke .env.production sebelum `npm run build` di server/CI.
# VITE_APP_URL dipakai saat build (CSRF trustedOrigins) dan runtime (origin check).

NODE_ENV=production
ORIGIN=https://sis.example.com
VITE_APP_URL=https://sis.example.com

HOST=127.0.0.1
PORT=3000

DATABASE_URL=file:./data/ops-sis.db
UPLOAD_DIR=./uploads
STORAGE_PROVIDER=local

AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
