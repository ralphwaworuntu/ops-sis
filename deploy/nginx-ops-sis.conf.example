# Contoh site Nginx — ganti domain dan path SSL.
# Letakkan di /etc/nginx/sites-available/ops-sis lalu:
#   sudo ln -s /etc/nginx/sites-available/ops-sis /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

upstream ops_sis {
	server 127.0.0.1:3000;
	keepalive 32;
}

server {
	listen 80;
	server_name sis.example.com;
	return 301 https://$host$request_uri;
}

server {
	listen 443 ssl http2;
	server_name sis.example.com;

	# ssl_certificate     /etc/letsencrypt/live/sis.example.com/fullchain.pem;
	# ssl_certificate_key /etc/letsencrypt/live/sis.example.com/privkey.pem;

	client_max_body_size 25M;

	location / {
		proxy_pass http://ops_sis;
		proxy_http_version 1.1;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
	}

	# SSE — tanpa buffering, timeout panjang
	location /api/events {
		proxy_pass http://ops_sis;
		proxy_http_version 1.1;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_set_header Connection '';
		proxy_buffering off;
		proxy_cache off;
		proxy_read_timeout 86400s;
		chunked_transfer_encoding off;
	}
}
